#!/usr/bin/env bash
# herdr-msg — herdr pane間のエージェントメッセージングヘルパー
#
# エージェントTUI宛の送信は、Enterの取りこぼしを避けるため send-text と
# send-keys Enter を分割して行う。`herdr pane run` はpaste終端とEnterを
# 同一チャンクで送るため、herdrのバージョンによってはTUIがEnterを取りこぼし、
# 入力欄にテキストが残る。
# (シェル宛は readline が正しく処理するため `herdr pane run` のままでよい)
#
# usage:
#   herdr-msg list [agent]                 エージェントpaneの一覧 (jsonl)
#   herdr-msg send <pane_id> <text>        1行テキストを送信してEnter
#   herdr-msg consult <agent|pane_id> <本文>
#                                          相談を送る。agent名(claude/codex等)なら
#                                          同一タブ > 同一cwd の優先順でpaneを自動選択。
#                                          [consult from=...] と返信手順を自動付与
#   herdr-msg pick <agent>                 consultの自動選択結果のpane_idだけ表示(送信しない)
#   herdr-msg reply <pane_id[@terminal_id]> <本文>
#                                          [reply from=...] を付与して返信。
#                                          @terminal_id付きなら現在のpane_idを
#                                          引き直して誤送信を防ぐ
#
#   herdr-msg <pane_id> <text> は send の省略形(後方互換)
set -euo pipefail

usage() {
    sed -n '2,/^set -euo pipefail/p' "$0" | sed 's/^# \{0,1\}//; $d'
}

die() {
    echo "herdr-msg: $*" >&2
    exit 1
}

require_env() {
    [ "${HERDR_ENV:-}" = "1" ] || die "not inside herdr (HERDR_ENV != 1)"
}

# 1行テキストを pane に送って Enter で確定する
deliver() {
    local pane="$1" text="$2"
    case "$text" in
        *$'\n'*) die "message must be a single line. write long content to a file and send its path instead" ;;
    esac
    [ -n "$text" ] || die "empty message"
    herdr pane send-text "$pane" "$text"
    # TUIがpasteされたテキストを処理し終える前にEnterが届くと取りこぼされる
    # ことがあるため、送信間隔を空ける
    sleep 0.3
    herdr pane send-keys "$pane" Enter
}

# 自分以外のエージェントpaneを jsonl で出力 (引数で agent 名を絞り込み)
list_agents() {
    herdr pane list | jq -c --arg a "${1:-}" --arg self "${HERDR_PANE_ID:-}" '
        .result.panes[]
        | select(.agent != null and .pane_id != $self)
        | select($a == "" or .agent == $a)
        | {pane_id, agent, agent_status, tab_id, cwd, title: .terminal_title_stripped}'
}

# 相談先paneを1つ選ぶ。同一タブ > 同一cwd の順で絞り込み、
# タブ・cwdどちらにも一致する候補がなければ自動選択せず失敗する。
# 絞り込み後も複数残って決めきれない場合も候補を出して失敗する
pick_pane() {
    local agent="$1" candidates pool narrowed my_tab matched=0
    candidates=$(list_agents "$agent")
    [ -n "$candidates" ] || die "no pane found for agent '$agent'"

    pool="$candidates"
    my_tab=$(herdr pane get "$HERDR_PANE_ID" | jq -r '.result.pane.tab_id')
    narrowed=$(jq -c --arg t "$my_tab" 'select(.tab_id == $t)' <<<"$pool")
    if [ -n "$narrowed" ]; then
        pool="$narrowed"
        matched=1
    fi
    narrowed=$(jq -c --arg cwd "$PWD" 'select(.cwd == $cwd)' <<<"$pool")
    if [ -n "$narrowed" ]; then
        pool="$narrowed"
        matched=1
    fi

    if [ "$matched" -eq 0 ]; then
        {
            echo "herdr-msg: no '$agent' pane in the same tab or cwd. specify one explicitly: herdr-msg consult <pane_id> <本文>"
            jq -c . <<<"$candidates"
        } >&2
        exit 2
    fi

    if [ "$(wc -l <<<"$pool")" -gt 1 ]; then
        {
            echo "herdr-msg: multiple '$agent' panes found. pick one and rerun: herdr-msg consult <pane_id> <本文>"
            jq -c . <<<"$pool"
        } >&2
        exit 2
    fi
    jq -r '.pane_id' <<<"$pool"
}

# terminal_id から現在のpane_idを引く (再割当を自己修復するため)
resolve_terminal() {
    local term="$1" pane_id
    pane_id=$(herdr pane list | jq -r --arg t "$term" '.result.panes[] | select(.terminal_id == $t) | .pane_id' | head -n1)
    [ -n "$pane_id" ] || die "reply target terminal $term not found (the sender pane may have been closed)"
    echo "$pane_id"
}

cmd="${1:-}"
case "$cmd" in
    help|-h|--help|"")
        usage
        exit 0
        ;;
    list)
        require_env
        list_agents "${2:-}"
        ;;
    pick)
        require_env
        [ $# -ge 2 ] || die "usage: herdr-msg pick <agent>"
        pick_pane "$2"
        ;;
    send)
        require_env
        [ $# -ge 3 ] || die "usage: herdr-msg send <pane_id> <text>"
        pane="$2"
        shift 2
        deliver "$pane" "$*"
        ;;
    reply)
        require_env
        [ $# -ge 3 ] || die "usage: herdr-msg reply <pane_id[@terminal_id]> <本文>"
        [ -n "${HERDR_PANE_ID:-}" ] || die "HERDR_PANE_ID is not set"
        target="$2"
        shift 2
        if [[ "$target" == *@* ]]; then
            term="${target#*@}"
            pane=$(resolve_terminal "$term")
        else
            pane="$target"
            target_agent=$(herdr pane get "$pane" | jq -r '.result.pane.agent // empty')
            [ -n "$target_agent" ] || die "reply target $pane is not an agent pane (it may have been closed and reassigned). find the sender again with: herdr-msg list"
        fi
        deliver "$pane" "[reply from=$HERDR_PANE_ID] $*"
        ;;
    consult)
        require_env
        [ $# -ge 3 ] || die "usage: herdr-msg consult <agent|pane_id> <本文>"
        [ -n "${HERDR_PANE_ID:-}" ] || die "HERDR_PANE_ID is not set"
        target="$2"
        shift 2
        # pane ID指定 (例: w1:pA) ならそのまま、agent名なら自動選択
        if list_agents | jq -e --arg p "$target" 'select(.pane_id == $p)' >/dev/null 2>&1; then
            pane="$target"
        else
            pane=$(pick_pane "$target")
        fi
        my_term=$(herdr pane get "$HERDR_PANE_ID" | jq -er '.result.pane.terminal_id')
        deliver "$pane" "[consult from=$HERDR_PANE_ID@$my_term] $* (返信は herdr-msg reply $HERDR_PANE_ID@$my_term '<返事を1行で>' で送って。長くなる場合はファイルに書いてそのパスを伝えて)"
        echo "consult sent to $pane" >&2
        ;;
    *)
        # 後方互換: herdr-msg <pane_id> <text>
        require_env
        [ $# -ge 2 ] || { usage >&2; exit 2; }
        pane="$1"
        shift
        deliver "$pane" "$*"
        ;;
esac
