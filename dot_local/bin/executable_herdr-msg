#!/usr/bin/env bash
# herdr-msg — herdr pane間のエージェントメッセージングヘルパー
#
# エージェントTUI宛の送信は、Enterの取りこぼしを避けるため agent send と
# send-keys Enter を分割して行う。`herdr pane run` はpaste終端とEnterを
# 同一チャンクで送るため、herdrのバージョンによってはTUIがEnterを取りこぼし、
# 入力欄にテキストが残る。
# (シェル宛は readline が正しく処理するため `herdr pane run` のままでよい)
#
# usage:
#   herdr-msg list [agent]                 エージェント一覧 (jsonl)
#   herdr-msg send <agent_target> <text>   1行テキストを送信してEnter
#   herdr-msg consult <agent|pane_id|terminal_id> <本文>
#                                          相談を送る。agent名(claude/codex等)なら
#                                          同一タブ > 同一cwd の優先順で自動選択。
#                                          [consult from=...] と返信ヒントを自動付与
#   herdr-msg pick <agent>                 自動選択結果のterminal_idだけ表示(送信しない)
#   herdr-msg history [n]                  送信履歴の末尾n件を表示(デフォルト20)
#   herdr-msg reply <reply_address> <本文>
#                                          [reply from=...] を付与して返信。
#                                          terminal_idで現在のpaneを引き直し、
#                                          agent_session_idで同一sessionか検証する
#
#   herdr-msg <agent_target> <text> は send の省略形(後方互換)
set -euo pipefail

usage() {
    sed -n '2,/^set -euo pipefail/p' "$0" | sed 's/^# \{0,1\}//; $d'
}

die() {
    echo "herdr-msg: $*" >&2
    exit 1
}

require_env() {
    [ "${HERDR_ENV:-}" = "1" ] || die "not inside herdr (HERDR_ENV != 1)"
}

# agent targetを解決する。terminal_idはpane IDの再割当後も同じlive terminalを指す
agent_info() {
    local target="$1" response message
    if ! response=$(herdr agent get "$target" 2>&1); then
        message=$(jq -r '.error.message // empty' <<<"$response" 2>/dev/null || true)
        die "${message:-failed to resolve agent target $target}"
    fi
    jq -ec '.result.agent' <<<"$response"
}

session_id() {
    jq -r '.agent_session.value // empty'
}

validate_session() {
    local info="$1" expected="$2" note="${3:-}" current
    [ -n "$expected" ] || return 0
    current=$(session_id <<<"$info")
    [ "$current" = "$expected" ] ||
        die "agent session changed for $(jq -r '.terminal_id' <<<"$info") (expected $expected, got ${current:-none})${note:+; $note}"
}

# 自分の返信先アドレスを terminal_id[@agent_session_id] で作る
self_address() {
    local info terminal session
    [ -n "${HERDR_PANE_ID:-}" ] || die "HERDR_PANE_ID is not set"
    info=$(agent_info "$HERDR_PANE_ID")
    terminal=$(jq -er '.terminal_id' <<<"$info")
    session=$(session_id <<<"$info")
    if [ -n "$session" ]; then
        printf '%s@%s\n' "$terminal" "$session"
    else
        printf '%s\n' "$terminal"
    fi
}

# ログ用の送信元。agent情報を取れなければpane IDへフォールバックする
log_address() {
    local address
    if address=$(self_address 2>/dev/null); then
        printf '%s\n' "$address"
    elif [ -n "${HERDR_PANE_ID:-}" ]; then
        printf '%s\n' "$HERDR_PANE_ID"
    fi
    return 0
}

history_file() {
    printf '%s/.local/state/herdr-msg/log.jsonl\n' "$HOME"
}

# ログ失敗は送信結果に影響させない
append_log() {
    local kind="$1" from="$2" to="$3" text="$4" file dir
    file=$(history_file)
    dir=${file%/*}
    (
        umask 077
        ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ') &&
            mkdir -p "$dir" &&
            jq -cn \
                --arg ts "$ts" \
                --arg kind "$kind" \
                --arg from "$from" \
                --arg to "$to" \
                --arg text "$text" \
                '{
                    ts: $ts,
                    kind: $kind,
                    from: (if $from == "" then null else $from end),
                    to: $to,
                    text: $text
                }' >>"$file"
    ) 2>/dev/null || true
}

# 1行テキストをagentへ送り、直前に宛先を再検証してEnterで確定する
deliver() {
    local target="$1" text="$2" kind="$3" from="$4" expected_session="${5:-}" info terminal pane
    case "$text" in
        *$'\n'*) die "message must be a single line. write long content to a file and send its path instead" ;;
    esac
    [ -n "$text" ] || die "empty message"

    info=$(agent_info "$target")
    validate_session "$info" "$expected_session"
    terminal=$(jq -er '.terminal_id' <<<"$info")
    herdr agent send "$terminal" "$text" >/dev/null

    # TUIがpasteされたテキストを処理し終える前にEnterが届くと取りこぼされる
    # ことがあるため、送信間隔を空ける
    sleep 0.3

    # 待機中にpane IDやagent sessionが変わっていないか再確認する
    info=$(agent_info "$terminal")
    validate_session "$info" "$expected_session" "the text may remain unsubmitted in the target input"
    pane=$(jq -er '.pane_id' <<<"$info")
    herdr pane send-keys "$pane" Enter
    append_log "$kind" "$from" "$terminal" "$text"
}

# 自分以外のエージェントをjsonlで出力 (引数でagent名を絞り込み)
list_agents() {
    herdr agent list | jq -c --arg a "${1:-}" --arg self "${HERDR_PANE_ID:-}" '
        .result.agents[]
        | select(.pane_id != $self)
        | select($a == "" or .agent == $a)
        | {
            terminal_id,
            pane_id,
            agent,
            agent_session_id: (.agent_session.value // null),
            agent_status,
            tab_id,
            cwd: (.foreground_cwd // .cwd),
            title: .terminal_title_stripped
        }'
}

# 相談先agentを1つ選ぶ。同一タブ > 同一cwd の順で絞り込み、
# タブ・cwdどちらにも一致する候補がなければ自動選択せず失敗する。
# 絞り込み後も複数残って決めきれない場合も候補を出して失敗する
pick_agent() {
    local agent="$1" candidates pool narrowed self my_tab my_cwd matched=0
    candidates=$(list_agents "$agent")
    [ -n "$candidates" ] || die "no agent found for '$agent'"

    pool="$candidates"
    self=$(agent_info "$HERDR_PANE_ID")
    my_tab=$(jq -er '.tab_id' <<<"$self")
    my_cwd=$(jq -er '.foreground_cwd // .cwd' <<<"$self")
    narrowed=$(jq -c --arg t "$my_tab" 'select(.tab_id == $t)' <<<"$pool")
    if [ -n "$narrowed" ]; then
        pool="$narrowed"
        matched=1
    fi
    narrowed=$(jq -c --arg cwd "$my_cwd" 'select(.cwd == $cwd)' <<<"$pool")
    if [ -n "$narrowed" ]; then
        pool="$narrowed"
        matched=1
    fi

    if [ "$matched" -eq 0 ]; then
        {
            echo "herdr-msg: no '$agent' agent in the same tab or cwd. specify one explicitly: herdr-msg consult <terminal_id> <本文>"
            jq -c . <<<"$candidates"
        } >&2
        exit 2
    fi

    if [ "$(wc -l <<<"$pool")" -gt 1 ]; then
        {
            echo "herdr-msg: multiple '$agent' agents found. pick one and rerun: herdr-msg consult <terminal_id> <本文>"
            jq -c . <<<"$pool"
        } >&2
        exit 2
    fi
    jq -er '.terminal_id' <<<"$pool"
}

# 新形式 terminal_id@session_id と旧形式 pane_id@terminal_idを解釈する
parse_reply_address() {
    local address="$1"
    reply_target="$address"
    reply_session=""
    case "$address" in
        term_*@*)
            reply_target="${address%%@*}"
            reply_session="${address#*@}"
            ;;
        *@term_*)
            reply_target="${address#*@}"
            ;;
    esac
}

cmd="${1:-}"
case "$cmd" in
    help|-h|--help|"")
        usage
        exit 0
        ;;
    list)
        require_env
        list_agents "${2:-}"
        ;;
    pick)
        require_env
        [ $# -ge 2 ] || die "usage: herdr-msg pick <agent>"
        pick_agent "$2"
        ;;
    history)
        [ $# -le 2 ] || die "usage: herdr-msg history [n]"
        count="${2:-20}"
        [[ "$count" =~ ^[0-9]+$ ]] || die "history count must be a non-negative integer"
        file=$(history_file)
        [ -f "$file" ] || exit 0
        tail -n "$count" -- "$file"
        ;;
    send)
        require_env
        [ $# -ge 3 ] || die "usage: herdr-msg send <agent_target> <text>"
        target="$2"
        shift 2
        from=$(log_address)
        deliver "$target" "$*" "send" "$from"
        ;;
    reply)
        require_env
        [ $# -ge 3 ] || die "usage: herdr-msg reply <reply_address> <本文>"
        address="$2"
        shift 2
        parse_reply_address "$address"
        from=$(self_address)
        deliver "$reply_target" "[reply from=$from] $*" "reply" "$from" "$reply_session"
        ;;
    consult)
        require_env
        [ $# -ge 3 ] || die "usage: herdr-msg consult <agent|pane_id|terminal_id> <本文>"
        target="$2"
        shift 2
        # pane/terminal ID指定ならterminal IDへ正規化し、agent名なら自動選択
        terminal=$(list_agents | jq -rs --arg t "$target" '
            map(select(.pane_id == $t or .terminal_id == $t))[0].terminal_id // empty
        ')
        if [ -n "$terminal" ]; then
            target="$terminal"
        else
            target=$(pick_agent "$target")
        fi
        from=$(self_address)
        deliver "$target" "[consult from=$from] $* (reply: herdr-msg reply $from '...')" "consult" "$from"
        echo "consult sent to $target" >&2
        ;;
    *)
        # 後方互換: herdr-msg <agent_target> <text>
        require_env
        [ $# -ge 2 ] || { usage >&2; exit 2; }
        target="$1"
        shift
        from=$(log_address)
        deliver "$target" "$*" "send" "$from"
        ;;
esac
